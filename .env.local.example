# Inspection mode (upstream)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# First Visit (Onboarding hub)
NEXT_PUBLIC_HUB_SUPABASE_URL=
NEXT_PUBLIC_HUB_SUPABASE_ANON_KEY=

# Dev-only — bypass auth and use service-role to read/write the hub
# without going through Google SSO. NEVER set this in production env.
NEXT_PUBLIC_DEV_SKIP_AUTH=1
HUB_SUPABASE_SERVICE_ROLE_KEY=
# Optional: who appears as inspector_email when no session is present
# DEV_INSPECTOR_EMAIL=you@arbio.com
